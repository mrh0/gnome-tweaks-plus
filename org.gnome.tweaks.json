{
    "app-id" : "org.gnome.tweaks",
    "runtime" : "org.gnome.Sdk",
    "runtime-version" : "49",
    "sdk" : "org.gnome.Sdk",
    "command" : "start-gnome-tweaks",
    "tags" : [
        "devel"
    ],
    "desktop-file-name-prefix" : "(Development) ",
    "finish-args" : [
        "--device=dri",
        "--env=GIO_EXTRA_MODULES=/app/lib/gio/modules/",
        "--env=GTK_ICON_THEME_PATH=/app/share/icons:/usr/share/icons:/usr/local/share/icons:/run/host/usr/share/icons",
        "--env=XDG_DATA_DIRS=/app/share:/usr/share:/usr/local/share:/run/host/usr/share:/run/host/usr/local/share",
        "--env=GSETTINGS_SCHEMA_DIR=/app/share/glib-2.0/schemas:/run/host/usr/share/glib-2.0/schemas:/run/host/usr/lib/x86_64-linux-gnu/glib-2.0/schemas",
        "--env=DCONF_USER_CONFIG_DIR=.config/dconf",
        "--env=XDG_CURRENT_DESKTOP=GNOME",
        "--filesystem=xdg-run/dconf",
        "--filesystem=xdg-config/dconf",
        "--filesystem=xdg-config/gnome-shell:ro",
        "--filesystem=xdg-data/icons:ro",
        "--filesystem=xdg-data/pixmaps:ro",
        "--filesystem=xdg-data/backgrounds:ro",
        "--filesystem=/run/host/usr/share/icons:ro",
        "--filesystem=/run/host/usr/share/themes:ro",
        "--filesystem=/run/host/usr/share/pixmaps:ro",
        "--filesystem=/run/host/usr/share/glib-2.0:ro",
        "--filesystem=/run/host/usr/lib/x86_64-linux-gnu/glib-2.0:ro",
        "--filesystem=/run/host/usr/share/gnome-shell:ro",
        "--filesystem=/usr/share/fonts:ro",
        "--socket=pulseaudio",
        "--socket=system-bus",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--share=ipc",
        "--talk-name=ca.desrt.dconf",
        "--talk-name=org.gnome.Shell",
        "--talk-name=org.gnome.Shell.Extensions",
        "--talk-name=org.gnome.SettingsDaemon",
        "--talk-name=org.freedesktop.UPower",
        "--talk-name=net.hadess.PowerProfiles",
        "--talk-name=org.freedesktop.Flatpak",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.gnome.Mutter.DisplayConfig"
    ],
    "cleanup" : [
        "/include",
        "/lib/*.la",
        "/lib/*.a",
        "/lib/pkgconfig",
        "/share/gir-1.0"
    ],
    "modules" : [
        {
            "name" : "gnome-desktop",
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/GNOME/gnome-desktop.git"
                }
            ]
        },
        {
            "name" : "dconf",
            "buildsystem" : "meson",
            "config-opts" : [
                "-Dbash_completion=false",
                "-Dman=false"
            ],
            "cleanup" : [
                "/include",
                "/lib/pkgconfig",
                "/libexec",
                "/share/dbus-1"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://download.gnome.org/sources/dconf/0.40/dconf-0.40.0.tar.xz",
                    "sha256" : "cf7f22a4c9200421d8d3325c5c1b8b93a36843650c9f95d6451e20f0bcb24533"
                },
                {
                    "type" : "patch",
                    "path" : "dconf-override.patch"
                }
            ]
        },
        {
            "name" : "scripts",
            "buildsystem" : "simple",
            "build-commands" : [
                "install -Dm 755 start-gnome-tweaks.sh /app/bin/start-gnome-tweaks"
            ],
            "sources" : [
                {
                    "type" : "file",
                    "path" : "start-gnome-tweaks.sh"
                }
            ]
        },
        {
            "name" : "gnome-tweaks",
            "buildsystem" : "meson",
            "config-opts" : [
                "-Dprofile=development",
                "--libdir=lib"
            ],
            "sources" : [
                {
                    "type" : "dir",
                    "path" : "."
                }
            ]
        }
    ],
    "build-options" : {
        "env" : {        }
    }
}
